# PocketTracker release signing — TEMPLATE
#
# 1. Copy this file to "keystore.properties" (gitignored) in the repo root.
# 2. Generate a keystore ONCE. Easiest via Android Studio:
#       Build > Generate Signed App Bundle / APK > APK > Create new...
#    Or on the command line:
#       keytool -genkeypair -v -keystore pockettracker-release.jks -alias pockettracker -keyalg RSA -keysize 4096 -validity 10000
# 3. Fill in the values below, then BACK UP the keystore file + password somewhere safe.
#    Losing the key means you can't ship updates that install over the published app.
#
# storeFile is resolved relative to the repo root; an absolute path also works.
# With a PKCS12 keystore (keytool's default), storePassword and keyPassword are the same value.

storeFile=pockettracker-release.jks
storePassword=CHANGE_ME
keyAlias=pockettracker
keyPassword=CHANGE_ME
