// Windows resources for the SDL shell — convergence plan A3.
//
// configure_file() turns this into pockettracker.rc in the build tree, substituting the icon's
// absolute path and the version parsed out of app/build.gradle.kts. It is a .in rather than a
// plain .rc precisely so neither of those is written down twice.
//
// ⚠️ THE ICON RESOURCE IS ALSO THE WINDOW ICON, and that is why there is no SDL_SetWindowIcon call
// anywhere in the shell. SDL2's SDL_RegisterApp (src/video/windows/SDL_windowsevents.c) sets the
// window class icon from SDL_HINT_WINDOWS_INTRESOURCE_ICON if that hint is set, and OTHERWISE
// EnumResourceNames(RT_GROUP_ICON) and takes the first one — its own comment says "use the first
// icon as a default icon, like in the Explorer". So embedding one icon here gets the Explorer icon,
// the taskbar icon and the window icon together, with no C++ change.
//
// That matters beyond convenience: SDL_SetWindowIcon takes an SDL_Surface, which would mean
// DECODING a PNG at start-up, and there is no image decoder anywhere in the C++ tree (convergence
// plan D2 — stb_image is not vendored until Phase D, and then into the shell only). The resource
// route sidesteps the question entirely rather than pulling Phase D's dependency forward.
//
// ⚠️ Keep this the ONLY icon in the binary, or "the first one" stops being a well-defined choice:
// EnumResourceNames walks resources in the order the linker emitted them, not in ID order.

#include <windows.h>

1 ICON "@PT_ICON@"

// The application manifest — activeCodePage=UTF-8, and why that is load-bearing, is explained in
// the file itself. Numeric resource type on purpose: 1 is CREATEPROCESS_MANIFEST_RESOURCE_ID and
// 24 is RT_MANIFEST, and spelling them as numbers means this line does not depend on which SDK
// header happens to define the macros for whichever resource compiler is in use.
1 24 "@PT_MANIFEST@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @PT_VERSION_COMMA@
 PRODUCTVERSION @PT_VERSION_COMMA@
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // 0409 = en-US, 04b0 = Unicode. Must agree with the Translation value below, and the two
        // disagreeing is the classic reason a version tab renders blank.
        BLOCK "040904b0"
        BEGIN
            VALUE "ProductName",      "PocketTracker"
            VALUE "FileDescription",  "PocketTracker - a tracker for small screens"
            VALUE "FileVersion",      "@PT_VERSION@"
            VALUE "ProductVersion",   "@PT_VERSION@"
            VALUE "InternalName",     "pockettracker-sdl"
            VALUE "OriginalFilename", "PocketTracker.exe"
            VALUE "LegalCopyright",   "GPL-3.0-or-later. See licenses\\LICENSE."
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
