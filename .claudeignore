# This file tells Claude Code which files/folders to ignore
# (similar to .gitignore)

# Build outputs - we don't need to read compiled files
/build/
/app/build/
*.apk
*.aab

# Gradle cache - temporary files
/.gradle/
.gradle/

# IDE files - Android Studio configuration
/.idea/
*.iml
local.properties

# Large binary files - too big and not useful to read
*.so
*.a
*.lib

# Generated files - created automatically
/app/src/main/gen/
/app/src/main/generated/

# Logs - usually not needed
*.log

# OS files
.DS_Store
Thumbs.db